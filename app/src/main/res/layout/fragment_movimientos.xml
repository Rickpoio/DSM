<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED"
    tools:context=".MovimientosFragment">

    <!-- HEADER -->

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:backgroundTint="@color/cyan"
        android:elevation="4dp">
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="35sp"
                android:textColor="@color/white"
                android:text="Registrar Movimiento"
                />
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENIDO -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp">

            <!-- CARD -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="0dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- BOTONES -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnIngreso"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="Ingreso"
                            android:textAllCaps="false"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            app:backgroundTint="#F3F3F3"
                            app:cornerRadius="14dp"
                            app:icon="@android:drawable/checkbox_on_background"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconTint="#2E7D32"
                            app:rippleColor="#DADADA"
                            app:strokeColor="#DADADA"
                            app:strokeWidth="1dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGasto"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Gasto"
                            android:textAllCaps="false"
                            android:textColor="#D32F2F"
                            android:textStyle="bold"
                            app:backgroundTint="#F3F3F3"
                            app:cornerRadius="14dp"
                            app:icon="@android:drawable/checkbox_on_background"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconTint="#D32F2F"
                            app:rippleColor="#DADADA"
                            app:strokeColor="#DADADA"
                            app:strokeWidth="1dp"/>

                    </LinearLayout>

                    <!-- TITULO -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="Título de movimiento"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#D9D9D9">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTitulo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0/200"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DESCRIPCION -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Descripción"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#D9D9D9">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescripcion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0/200"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- MONTO -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Monto:"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#D9D9D9">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMonto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="$0.00"
                            android:inputType="numberDecimal"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- CATEGORIA -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Categoría:"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@android:drawable/editbox_background"/>

                    <!-- FECHA -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Fecha:"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:hint="DD"
                                android:inputType="number"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMes"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:hint="MM"
                                android:inputType="number"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAnio"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:hint="YYYY"
                                android:inputType="number"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- METODO -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Método de pago:"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spMetodoPago"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:background="@android:drawable/editbox_background"/>

                    <!-- CHIPS -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Etiquetas:"
                        android:textColor="#1F1F1F"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="# Gym"
                            android:textColor="#2E7D32"
                            app:chipBackgroundColor="#F2F2F2"/>

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="# Almuerzo"
                            android:textColor="#2E7D32"
                            app:chipBackgroundColor="#F2F2F2"/>

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Añadir etiqueta"
                            android:textColor="#2E7D32"
                            app:chipBackgroundColor="#F2F2F2"/>

                    </com.google.android.material.chip.ChipGroup>

                    <!-- BOTONES FINALES -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGuardar"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1.4"
                            android:text="Guardar Movimiento"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#3CBF2D"
                            app:cornerRadius="12dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancelar"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="0.8"
                            android:text="Cancelar"
                            android:textAllCaps="false"
                            android:textColor="#1F1F1F"
                            app:backgroundTint="#FFFFFF"
                            app:cornerRadius="12dp"
                            app:strokeColor="#BDBDBD"
                            app:strokeWidth="1dp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>